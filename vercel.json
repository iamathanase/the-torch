{
  "version": 2,
  "builds": [
    {
      "src": "back/server.js",
      "use": "@vercel/node",
      "config": {
        "maxLambdaSize": "50mb",
        "nodeVersion": "18.x"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/.*",
      "dest": "back/server.js"
    },
    {
      "src": "/pages/.*",
      "dest": "/front/pages/",
      "methods": ["GET"]
    },
    {
      "src": "/assets/.*",
      "dest": "/front/assets/",
      "methods": ["GET"]
    },
    {
      "src": "/(.*)",
      "dest": "/front/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}



