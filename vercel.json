{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/front/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/front/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}



